{
  "info": {
    "name": "Book Management System API",
    "_postman_id": "c0b3b1c2-9f72-4cd2-94f2-9fb3ce9b6e11",
    "description": "图书管理系统接口集合。先执行 Auth/Login 获取 token，再测试受保护接口。",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "username", "value": "admin" },
    { "key": "password", "value": "admin123" },
    { "key": "bookId", "value": "1" },
    { "key": "borrowId", "value": "1" },
    { "key": "userId", "value": "2" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Save token from response', function () {",
                  "  const data = pm.response.json();",
                  "  pm.expect(data).to.have.property('token');",
                  "  pm.collectionVariables.set('token', data.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Current User (/auth/me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        },
        {
          "name": "Register User (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"123456\",\n  \"email\": \"newuser@test.com\",\n  \"role\": \"user\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            }
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Get Books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"]
            }
          }
        },
        {
          "name": "Get Book By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "{{bookId}}"]
            }
          }
        },
        {
          "name": "Create Book (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isbn\": \"9787300000001\",\n  \"title\": \"Postman 测试图书\",\n  \"author\": \"测试作者\",\n  \"publisher\": \"测试出版社\",\n  \"publish_date\": \"2025-01-01\",\n  \"category\": \"科技\",\n  \"total_quantity\": 5,\n  \"description\": \"用于接口测试\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books"]
            }
          }
        },
        {
          "name": "Update Book (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"更新后的图书\",\n  \"author\": \"更新作者\",\n  \"publisher\": \"更新出版社\",\n  \"publish_date\": \"2025-02-01\",\n  \"category\": \"文学\",\n  \"total_quantity\": 6,\n  \"description\": \"更新描述\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "{{bookId}}"]
            }
          }
        },
        {
          "name": "Delete Book (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/books/{{bookId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "books", "{{bookId}}"]
            }
          }
        }
      ]
    },
